<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Sayeem Admin Panel</title>

<link rel="stylesheet" href="admin.css">

</head>


<body>


<div class="sidebar">

<h2>Sayeem Admin</h2>

<a href="#">Dashboard</a>
<a href="#">Products</a>
<a href="#">Orders</a>
<a href="#">Customers</a>
<a href="#">Logout</a>


</div>



<div class="content">


<h1>Dashboard</h1>


<div class="cards">


<div class="card">

<h3>Total Products</h3>

<p id="totalProduct">0</p>

</div>



<div class="card">

<h3>Total Orders</h3>

<p>0</p>

</div>



<div class="card">

<h3>Total Customer</h3>

<p>0</p>

</div>


</div>




<h2>Add New Product</h2>


<form id="productForm">


<input type="text" id="productName" placeholder="Product Name">


<input type="text" id="productPrice" placeholder="Price">


<input type="text" id="productImage" placeholder="Image URL">


<textarea id="productDesc" placeholder="Description"></textarea>


<button type="submit">

Add Product

</button>


</form>



<h2>Product List</h2>


<table>


<tr>

<th>Name</th>

<th>Price</th>

<th>Action</th>

</tr>


<tbody id="productList">


</tbody>


</table>


</div>



<script src="admin.js"></script>


</body>

</html>
